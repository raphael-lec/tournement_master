            <input type="hidden" name="update_profile" value="1">
            <div class="form-group">
                <label>Nom d'utilisateur</label>
                <input type="text" name="name" value="<?php echo htmlspecialchars($user->getName()); ?>" class="form-input" required>
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" value="<?php echo htmlspecialchars($user->getEmail()); ?>" class="form-input" required>
