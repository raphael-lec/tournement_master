    <header class="page-header">
        <h1>Tous les <span class="text-accent">Tournois</span></h1>
        <p class="page-subtitle">Rejoignez une compétition en cours ou découvrez les résultats des précédents tournois.</p>
    </header>

    <section class="filter-section">
        <form action="index.php" method="GET" class="filter-form">
            <input type="hidden" name="action" value="tournaments">
            
            <div class="search-group">
                <input type="text" name="search" placeholder="Rechercher par jeu, titre ou organisateur..." class="form-input">
            </div>
            
            <div class="select-group">
                <select name="status" class="form-select">
                    <option value="">Tous les statuts</option>
                    <option value="open">Inscriptions ouvertes</option>
                    <option value="ongoing">En cours</option>
                    <option value="finished">Terminé</option>
                </select>

                <select name="format" class="form-select">
                    <option value="">Tous les formats</option>
                    <option value="1v1">1v1</option>
