                </select>

                <button type="submit" class="btn btn-search">Filtrer</button>
            </div>
        </form>
    </section>

    <section class="tournaments-grid">
        
        <?php if (!empty($tournaments)): ?>
            <?php foreach ($tournaments as $tournament): ?>
                <div class="tournament-card">
                    <div class="card-header">
                        <?php
                            $status = $tournament['status'] ?? null;
                            $statusClass = 'badge-finished';
                            $statusLabel = 'Terminé';
                            if ($status === 'open') {
                                $statusClass = 'badge-open';
                                $statusLabel = 'Inscriptions Ouvertes';
                            } elseif ($status === 'ongoing') {
                                $statusClass = 'badge-ongoing';
                                $statusLabel = 'En cours';
                            }
                        ?>
                        <span class="badge <?php echo $statusClass; ?>"><?php echo $statusLabel; ?></span>
                        <span class="tournament-format"><?php echo htmlspecialchars($tournament['format']); ?></span>
                    </div>

                    <div class="card-body">
                        <h3 class="tournament-title"><?php echo htmlspecialchars($tournament['name']); ?></h3>
                        <p class="tournament-info">📅 Date : <?php echo htmlspecialchars($tournament['date']); ?></p>
                        <p class="tournament-info">👥 Max participants : <?php echo (int)$tournament['max_participant']; ?></p>
                    </div>

                    <div class="card-footer">
                        <a href="index.php?route=tournemant_home&id=<?php echo $tournament['id']; ?>" class="btn btn-card-action">
                            Voir le tournoi
                        </a>
                    </div>
                </div>
            <?php endforeach; ?>
        <?php else: ?>
            <div class="no-tournament">
                <p>Aucun tournoi ne correspond à votre recherche pour le moment. 🏆</p>
            </div>
        <?php endif; ?>

    </section>
</div>