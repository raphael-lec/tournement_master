<?php $status = $tournament['status']; ?>
<div class="tournament-home">

    <header class="tournament-header">
        <h1> <?php echo htmlspecialchars($tournament['name']); ?></h1>
        <div class="tournament-meta">
            <?php
                $badgeClass = match($status) {
                    'open'    => 'badge-open',
                    'ongoing' => 'badge-ongoing',
                    default   => 'badge-finished'
                };
                $badgeLabel = match($status) {
                    'open'    => 'Inscriptions ouvertes',
                    'ongoing' => 'En cours',
                    default   => 'Terminé'
                };
            ?>
            <span class="badge <?php echo $badgeClass; ?>"><?php echo $badgeLabel; ?></span>
            <span> <?php echo htmlspecialchars($tournament['date']); ?></span>
            <span> <?php echo $teamsCount; ?> / <?php echo $tournament['max_participant']; ?> équipes</span>
            <?php if (!empty($tournament['discord_link'])): ?>
                <a href="<?php echo htmlspecialchars($tournament['discord_link']); ?>" target="_blank" class="discord-link">
                     Rejoindre le Discord
                </a>
            <?php endif; ?>
        </div>
    </header>

    <?php if ($message): ?>
        <div class="alert alert-<?php echo $message['type']; ?>">
            <?php echo htmlspecialchars($message['text']); ?>
        </div>
    <?php endif; ?>

    <?php if ($status === 'open'): ?>
        <section class="register-section">
            <h2> Inscription</h2>

            <?php if ($teamsCount >= $tournament['max_participant']): ?>
                <p class="full-notice"> Le tournoi est complet.</p>

            <?php elseif ($isConnected): ?>
                <?php $format = (int)$tournament['format']; ?>
                <p>Places restantes : <strong><?php echo $tournament['max_participant'] - $teamsCount; ?></strong></p>

                <form method="POST" action="index.php?route=tournemant_home&id=<?php echo $tournament['id']; ?>" class="register-form">
                    <input type="hidden" name="register" value="1">

                    <div class="form-group">
                        <label>Nom de l'équipe</label>
                        <input type="text" name="team_name" placeholder="Ex: Les Invincibles" required class="form-input">
                    </div>

                    <?php if ($format > 1): ?>
                        <div class="form-group">
                            <label>
                                Choisir des coéquipiers
                                <small>(<?php echo $format - 1; ?> coéquipier<?php echo $format > 2 ? 's' : ''; ?> à sélectionner)</small>
                            </label>
                            <p class="format-info"> Ce tournoi est en <strong><?php echo $format; ?>v<?php echo $format; ?></strong> — sélectionnez exactement <?php echo $format - 1; ?> coéquipier<?php echo $format > 2 ? 's' : ''; ?>.</p>
                            <div class="members-list">
                                <?php foreach ($allUsers as $u): ?>
                                    <?php if ($u['id'] !== ($user ? $user->getId() : 0)): ?>
                                        <label class="member-option">
                                            <input type="checkbox" name="members[]" value="<?php echo $u['id']; ?>" class="member-checkbox">
                                            <?php echo htmlspecialchars($u['name']); ?>
                                        </label>
                                    <?php endif; ?>
                                <?php endforeach; ?>
                            </div>
                        </div>
                    <?php else: ?>
                        <p class="format-info"> Ce tournoi est en <strong>1v1</strong> — vous jouez seul.</p>
                    <?php endif; ?>

                    <button type="submit" class="btn btn-register"> S'inscrire</button>
                </form>

                <script>
                const maxMembers = <?php echo $format - 1; ?>;
                const checkboxes = document.querySelectorAll('.member-checkbox');
                checkboxes.forEach(cb => {
                    cb.addEventListener('change', () => {
                        const checked = document.querySelectorAll('.member-checkbox:checked');
                        if (checked.length >= maxMembers) {
                            checkboxes.forEach(c => { if (!c.checked) c.disabled = true; });
                        } else {
                            checkboxes.forEach(c => c.disabled = false);
                        }
                    });
                });
                </script>

            <?php else: ?>
                <p><a href="index.php?route=login">Connectez-vous</a> pour vous inscrire.</p>
            <?php endif; ?>
        </section>
    <?php endif; ?>

    <?php if ($status === 'ongoing'): ?>
        <section class="matches-section">
            <h2>Matchs en cours</h2>
            <?php if (empty($matches)): ?>
                <p>Aucun match programmé pour l'instant.</p>
            <?php else: ?>
                <table class="matches-table">
                    <thead>
                        <tr>
                            <th>Équipe 1</th>
                            <th>Score</th>
                            <th>Équipe 2</th>
                        </tr>
                    </thead>
                    <tbody>
                        <?php foreach ($matches as $match): ?>
                            <tr>
                                <td><?php echo htmlspecialchars($match['team1_name'] ?? '?'); ?></td>
                                <td><?php echo $match['score_team_1']; ?> - <?php echo $match['score_team_2']; ?></td>
                                <td><?php echo htmlspecialchars($match['team2_name'] ?? '?'); ?></td>
                            </tr>
                        <?php endforeach; ?>
                    </tbody>
                </table>
            <?php endif; ?>
        </section>
    <?php endif; ?>

    <?php if ($status === 'finish'): ?>
        <section class="results-section">

            <?php if (!empty($winnerName)): ?>
                <div class="podium-banner">
                    <div class="podium-place podium-first"> 1er : <strong><?php echo htmlspecialchars($winnerName); ?></strong></div>
                    <?php if (!empty($runnerUpName)): ?>
                        <div class="podium-place podium-second"> 2ème : <strong><?php echo htmlspecialchars($runnerUpName); ?></strong></div>
                    <?php endif; ?>
                </div>
            <?php endif; ?>

            <h2> Résultats</h2>
            <?php if (empty($matches)): ?>
                <p>Aucun résultat disponible.</p>
            <?php else: ?>
                <?php
                    $phases = [
                        'poule'  => 'Phase de poules',
                        'quart'  => ' Quarts de finale',
                        'demi'   => ' Demi-finales',
                        'finale' => ' Finale',
                    ];

                    $matchesByPhase = [];
                    foreach ($matches as $match) {
                        $phase = $match['phase'] ?? 'poule';
                        $matchesByPhase[$phase][] = $match;
                    }
                ?>

                <?php foreach ($phases as $phaseKey => $phaseLabel): ?>
                    <?php if (!empty($matchesByPhase[$phaseKey])): ?>
                        <h3><?php echo $phaseLabel; ?></h3>

                        <?php if ($phaseKey === 'poule'): ?>
                            <?php
                                $poulesGrouped = [];
                                foreach ($matchesByPhase['poule'] as $m) {
                                    $poulesGrouped[$m['poule_name'] ?? 'A'][] = $m;
                                }
                            ?>
                            <?php foreach ($poulesGrouped as $pouleName => $pouleMatchs): ?>
                                <h4>Poule <?php echo htmlspecialchars($pouleName); ?></h4>
                                <table class="matches-table">
                                    <thead>
                                        <tr><th>Équipe 1</th><th>Score</th><th>Équipe 2</th><th>Gagnant</th></tr>
                                    </thead>
                                    <tbody>
                                        <?php foreach ($pouleMatchs as $match): ?>
                                            <tr>
                                                <td><?php echo htmlspecialchars($match['team1_name'] ?? '?'); ?></td>
                                                <td><?php echo $match['score_team_1']; ?> - <?php echo $match['score_team_2']; ?></td>
                                                <td><?php echo htmlspecialchars($match['team2_name'] ?? '?'); ?></td>
                                                <td> <?php
                                                    if ($match['winner_team_id'] > 0) {
                                                        echo htmlspecialchars($match['winner_team_id'] == $match['team1_id'] ? ($match['team1_name'] ?? '?') : ($match['team2_name'] ?? '?'));
                                                    } else { echo '—'; }
                                                ?></td>
                                            </tr>
                                        <?php endforeach; ?>
                                    </tbody>
                                </table>
                            <?php endforeach; ?>

                        <?php else: ?>
                            <table class="matches-table">
                                <thead>
                                    <tr><th>Équipe 1</th><th>Score</th><th>Équipe 2</th><th>Gagnant</th></tr>
                                </thead>
                                <tbody>
                                    <?php foreach ($matchesByPhase[$phaseKey] as $match): ?>
                                        <tr>
                                            <td><?php echo htmlspecialchars($match['team1_name'] ?? '?'); ?></td>
                                            <td><?php echo $match['score_team_1']; ?> - <?php echo $match['score_team_2']; ?></td>
                                            <td><?php echo htmlspecialchars($match['team2_name'] ?? '?'); ?></td>
                                            <td> <?php
                                                if ($match['winner_team_id'] > 0) {
                                                    echo htmlspecialchars($match['winner_team_id'] == $match['team1_id'] ? ($match['team1_name'] ?? '?') : ($match['team2_name'] ?? '?'));
                                                } else { echo '—'; }
                                            ?></td>
                                        </tr>
                                    <?php endforeach; ?>
                                </tbody>
                            </table>
                        <?php endif; ?>
                    <?php endif; ?>
                <?php endforeach; ?>
            <?php endif; ?>
        </section>

        <section class="participants-section">
            <h2> Équipes participantes</h2>
            <div class="teams-grid">
                <?php foreach ($teams as $team): ?>
                    <div class="team-card">
                        <h3>
                             <?php echo htmlspecialchars($team['name']); ?>
                            <?php if (!empty($winnerTeamId) && $team['id'] == $winnerTeamId): ?>
                                <span class="rank-badge rank-1">🥇 1er</span>
                            <?php elseif (!empty($runnerUpTeamId) && $team['id'] == $runnerUpTeamId): ?>
                                <span class="rank-badge rank-2">🥈 2ème</span>
                            <?php endif; ?>
                        </h3>
                        <ul>
                            <?php if (!empty($team['members'])): ?>
                                <?php foreach ($team['members'] as $member): ?>
                                    <li> <?php echo htmlspecialchars($member['name']); ?></li>
                                <?php endforeach; ?>
                            <?php else: ?>
                                <li><em>Aucun membre</em></li>
                            <?php endif; ?>
                        </ul>
                    </div>
                <?php endforeach; ?>
            </div>
        </section>
    <?php endif; ?>

</div>